-- test-vlist-pattern.fplang

let xs = [10, 20, 30]
let h = listHead(xs)
let t = listTail(xs)
println(strConcat("head [10,20,30] = ", intToStr(h)))
println(strConcat("tail length    = ", intToStr(listLen(t))))

let showList = fix(fn(self) => fn(xs) =>
  match(xs) {
    Nil        => "Nil"
  | Cons(h, t) => strConcat(intToStr(h), strConcat(" : ", self(t)))
  })

let cl = listToCons([3, 1, 4])
println(strConcat("cons form: ", showList(cl)))

let sum = fix(fn(self) => fn(xs) =>
  match(xs) {
    Nil        => 0
  | Cons(h, t) => intAdd(h, self(t))
  })
println(strConcat("sum [3,1,4] = ", intToStr(sum(listToCons([3, 1, 4])))))
