-- Recursion schemes: map, foldr, and filter for singly-linked cons-lists.

let showIntList = fix(fn(self) => fn(xs) =>
  match(xs) {
    Nil => "Nil"
  | Cons(h, t) => strConcat(strConcat(intToStr(h), " : "), self(t))
  })

let foldr = fix(fn(self) => fn(f, z, xs) =>
  match(xs) {
    Nil => z
  | Cons(h, t) => f(h, self(f, z, t))
  })

let map = fix(fn(self) => fn(f, xs) =>
  match(xs) {
    Nil => Tag Nil
  | Cons(h, t) => Tag Cons(f(h), self(f, t))
  })

let filter = fix(fn(self) => fn(pred, xs) =>
  match(xs) {
    Nil => Tag Nil
  | Cons(h, t) =>
      if pred(h)
      then Tag Cons(h, self(pred, t))
      else self(pred, t)
  })

let isEven = fix(fn(self) => fn(n) =>
  if intEq(n, 0) then true
  else if intEq(n, 1) then false
  else self(intSub(n, 2)))

let xs = Tag Cons(1, Tag Cons(2, Tag Cons(3, Tag Cons(4, Tag Cons(5, Tag Nil)))))

let sum     = foldr(fn(h, acc) => intAdd(h, acc), 0, xs)
let product = foldr(fn(h, acc) => intMul(h, acc), 1, xs)
let length  = foldr(fn(h, acc) => intAdd(1, acc), 0, xs)
let doubled = map(fn(x) => intMul(x, 2), xs)
let evens   = filter(isEven, xs)

println(strConcat("list    = ", showIntList(xs)))
println(strConcat("sum     = ", intToStr(sum)))
println(strConcat("product = ", intToStr(product)))
println(strConcat("length  = ", intToStr(length)))
println(strConcat("doubled = ", showIntList(doubled)))
println(strConcat("evens   = ", showIntList(evens)))
