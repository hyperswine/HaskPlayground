-- Recursion schemes: map, foldr, and filter for singly-linked cons-lists.
--
-- Cons-lists are built with:
--   Tag Nil              empty list
--   Tag Cons(head, tail) non-empty cell

-- ── show a cons-list of ints ─────────────────────────────────────────────────

let showIntList = fix showIntList(xs) =>
  match(xs) {
    Nil => "Nil"
  | Cons(h, t) => strConcat(strConcat(intToStr(h), " : "), showIntList(t))
  }

-- ── foldr(f, z, xs) ──────────────────────────────────────────────────────────
-- foldr f z [x1, x2, x3]  =  f(x1, f(x2, f(x3, z)))

let foldr = fix foldr(f, z, xs) =>
  match(xs) {
    Nil => z
  | Cons(h, t) => f(h, foldr(f, z, t))
  }

-- ── map(f, xs) ───────────────────────────────────────────────────────────────
-- map f [x1, x2, x3]  =  [f(x1), f(x2), f(x3)]

let map = fix map(f, xs) =>
  match(xs) {
    Nil => Tag Nil
  | Cons(h, t) => Tag Cons(f(h), map(f, t))
  }

-- ── filter(pred, xs) ─────────────────────────────────────────────────────────
-- filter pred [x1,x2,x3]  =  [xi | pred(xi) == true]

let filter = fix filter(pred, xs) =>
  match(xs) {
    Nil => Tag Nil
  | Cons(h, t) =>
      if pred(h)
      then Tag Cons(h, filter(pred, t))
      else filter(pred, t)
  }

-- ── isEven: true when n is even (works for n >= 0) ───────────────────────────

let isEven = fix isEven(n) =>
  if intEq(n, 0) then true
  else if intEq(n, 1) then false
  else isEven(intSub(n, 2))

-- ── Demo ─────────────────────────────────────────────────────────────────────

let xs = Tag Cons(1, Tag Cons(2, Tag Cons(3, Tag Cons(4, Tag Cons(5, Tag Nil)))))

let sum     = foldr(fn(h, acc) => intAdd(h, acc), 0, xs)
let product = foldr(fn(h, acc) => intMul(h, acc), 1, xs)
let length  = foldr(fn(h, acc) => intAdd(1, acc), 0, xs)
let doubled = map(fn(x) => intMul(x, 2), xs)
let evens   = filter(isEven, xs)

println(strConcat("list    = ", showIntList(xs)))
println(strConcat("sum     = ", intToStr(sum)))
println(strConcat("product = ", intToStr(product)))
println(strConcat("length  = ", intToStr(length)))
println(strConcat("doubled = ", showIntList(doubled)))
println(strConcat("evens   = ", showIntList(evens)))
