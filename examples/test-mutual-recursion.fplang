-- test-mutual-recursion.fplang
-- Simulates mutual recursion via higher-order passing.
-- isEven and isOdd call each other through arguments.

let makeEven = fn(odd) =>
  fix even(n) =>
    if intEq(n, 0) then true
    else odd(intSub(n, 1))

let makeOdd = fn(even) =>
  fix odd(n) =>
    if intEq(n, 0) then false
    else even(intSub(n, 1))

-- Tie the knot manually by building a shared env via a wrapper fix
let isEven = fix isEven(n) =>
  if intEq(n, 0) then true
  else {
    let isOdd = fix isOdd(m) =>
      if intEq(m, 0) then false
      else isEven(intSub(m, 1))
    isOdd(intSub(n, 1))
  }

println(strConcat("isEven(0) = ", showVal(isEven(0))))   -- true
println(strConcat("isEven(1) = ", showVal(isEven(1))))   -- false
println(strConcat("isEven(6) = ", showVal(isEven(6))))   -- true
println(strConcat("isEven(7) = ", showVal(isEven(7))))   -- false

-- Ackermann function (tests deep fix recursion)
let ack = fix ack(m, n) =>
  if intEq(m, 0) then intAdd(n, 1)
  else if intEq(n, 0) then ack(intSub(m, 1), 1)
  else ack(intSub(m, 1), ack(m, intSub(n, 1)))

println(strConcat("ack(0,0) = ", intToStr(ack(0, 0))))   -- 1
println(strConcat("ack(1,1) = ", intToStr(ack(1, 1))))   -- 3
println(strConcat("ack(2,3) = ", intToStr(ack(2, 3))))   -- 9
println(strConcat("ack(3,3) = ", intToStr(ack(3, 3))))   -- 61
