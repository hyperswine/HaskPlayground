-- test-mutual-recursion.fplang

let isEven = fix(fn(isEven) => fn(n) =>
  if intEq(n, 0) then true
  else {
    let isOdd = fix(fn(isOdd) => fn(m) =>
      if intEq(m, 0) then false
      else isEven(intSub(m, 1))
    )
    isOdd(intSub(n, 1))
  }
)

println(strConcat("isEven(0) = ", showVal(isEven(0))))
println(strConcat("isEven(1) = ", showVal(isEven(1))))
println(strConcat("isEven(6) = ", showVal(isEven(6))))
println(strConcat("isEven(7) = ", showVal(isEven(7))))

let ack = fix(fn(ack) => fn(m, n) =>
  if intEq(m, 0) then intAdd(n, 1)
  else if intEq(n, 0) then ack(intSub(m, 1), 1)
  else ack(intSub(m, 1), ack(m, intSub(n, 1)))
)

println(strConcat("ack(0,0) = ", intToStr(ack(0, 0))))
println(strConcat("ack(1,1) = ", intToStr(ack(1, 1))))
println(strConcat("ack(2,3) = ", intToStr(ack(2, 3))))
println(strConcat("ack(3,3) = ", intToStr(ack(3, 3))))
