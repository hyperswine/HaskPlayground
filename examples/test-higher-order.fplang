-- test-higher-order.fplang

let adder = fn(n) => fn(x) => intAdd(x, n)
let add5 = adder(5)
let add10 = adder(10)
println(strConcat("add5(3)  = ", intToStr(add5(3))))
println(strConcat("add10(3) = ", intToStr(add10(3))))

let compose = fn(f, g) => fn(x) => f(g(x))
let double = fn(x) => intMul(x, 2)
let inc    = fn(x) => intAdd(x, 1)
let doubleInc = compose(double, inc)
let incDouble = compose(inc, double)
println(strConcat("doubleInc(4) = ", intToStr(doubleInc(4))))
println(strConcat("incDouble(4) = ", intToStr(incDouble(4))))

let boxFn = Tag Boxed(fn(x) => intMul(x, 3))
let callBoxed = fn(b, v) => tagPayload(b)(v)
println(strConcat("boxed fn (4) = ", intToStr(callBoxed(boxFn, 4))))

-- fix is now a first-class Z-combinator
let makeCounter = fix(fn(self) => fn(n) => fn() => {
  let cur = n
  self(intAdd(n, 1))
})
let step0 = makeCounter(0)
let step1 = step0()
let step2 = step1()
println("closure chain: ok (no crash)")
